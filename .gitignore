# PDFs — source documents, never commit
*.pdf

# Outputs — Excel and large binaries excluded, audit trail tracked
DELIVERABLE/outputs/*.xlsx
DELIVERABLE/outputs/pillar3/
DELIVERABLE/outputs/CFO_Presentation/*.xlsx
DELIVERABLE/outputs/CFO_Presentation/*.json
# Slide PNGs are large — exclude to keep repo size manageable
DELIVERABLE/outputs/CFO_Presentation/audit/**/*.png

# Python
__pycache__/
*.pyc
*.pyo
.env
*.env

# Google Cloud SDK — too large
google-cloud-sdk/

# Excel lock files
~$*.xlsx

# macOS
.DS_Store
